<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aura Focus Engine</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono&display=swap');
        
        :root {
            --aura-bg: #030407;
            --aura-panel: #0d1117;
            --aura-accent: #818cf8;
            --aura-border: rgba(255, 255, 255, 0.08);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--aura-bg);
            color: #e2e8f0;
            overflow: hidden;
        }

        .mono { font-family: 'JetBrains Mono', monospace; }

        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: var(--aura-border); border-radius: 10px; }

        .glass {
            background: rgba(13, 17, 23, 0.8);
            backdrop-filter: blur(16px);
            border: 1px solid var(--aura-border);
        }

        .message-fade-in {
            animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .thinking-dots::after {
            content: '.';
            animation: dots 1.5s steps(5, end) infinite;
        }
        @keyframes dots { 0%, 20% { content: '.'; } 40% { content: '..'; } 60% { content: '...'; } 80%, 100% { content: ''; } }

        /* Enhanced Status Animations */
        .pulse-amber {
            animation: pulse-amber-glow 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse-amber-glow {
            0%, 100% { background-color: #fbbf24; box-shadow: 0 0 5px #fbbf24; opacity: 1; }
            50% { background-color: #d97706; box-shadow: 0 0 15px #fbbf24; opacity: 0.5; }
        }

        .pulse-indigo {
            animation: pulse-indigo-glow 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse-indigo-glow {
            0%, 100% { box-shadow: 0 0 5px rgba(129, 140, 248, 0.4); }
            50% { box-shadow: 0 0 20px rgba(129, 140, 248, 0.8); }
        }

        .focus-gradient {
            background: linear-gradient(180deg, rgba(129, 140, 248, 0.05) 0%, rgba(3, 4, 7, 0) 100%);
        }

        strong {
            color: #818cf8;
            font-weight: 700;
        }

        .loading-overlay {
            position: fixed;
            inset: 0;
            background: var(--aura-bg);
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.5s ease;
        }

        .animate-spin-slow {
            animation: spin 3s linear infinite;
        }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    </style>
</head>
<body class="h-screen flex">

    <div id="loader" class="loading-overlay">
        <div class="text-center">
            <div class="w-12 h-12 border-4 border-indigo-500/20 border-t-indigo-500 rounded-full animate-spin mb-4 mx-auto"></div>
            <p class="text-[10px] mono uppercase tracking-widest text-indigo-400">Syncing Flow State...</p>
        </div>
    </div>

    <!-- Sidebar -->
    <aside class="w-72 h-full glass border-r border-white/5 flex flex-col z-50 hidden md:flex">
        <div class="p-6 border-b border-white/5">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-xl bg-indigo-600 flex items-center justify-center shadow-lg shadow-indigo-500/20">
                    <i class="fas fa-bolt text-white"></i>
                </div>
                <div>
                    <h1 class="font-bold text-white tracking-tight">Aura Engine</h1>
                    <p id="user-display" class="text-[9px] text-white/30 mono tracking-widest uppercase">Initializing...</p>
                </div>
            </div>
            <button onclick="createNewFlow()" class="w-full py-2.5 bg-white/5 hover:bg-white/10 rounded-xl text-xs font-semibold flex items-center justify-center gap-2 transition-all border border-white/10 active:scale-95">
                <i class="fas fa-plus"></i> New Flow State
            </button>
        </div>

        <div id="flow-list" class="flex-1 overflow-y-auto p-4 space-y-2 custom-scrollbar"></div>

        <div class="p-4 border-t border-white/5 bg-black/40">
            <div id="status-container" class="flex flex-col items-center gap-2">
                <div class="flex items-center justify-center gap-2">
                    <div id="status-dot" class="w-2.5 h-2.5 rounded-full bg-white/10 transition-all duration-700"></div>
                    <span id="server-status" class="text-[8px] text-white/20 uppercase tracking-[0.2em] mono font-bold transition-all duration-500">Connecting...</span>
                </div>
                <div id="status-msg" class="text-[7px] text-white/10 mono uppercase tracking-tight opacity-50">Initializing Node</div>
            </div>
        </div>
    </aside>

    <!-- Main Workspace -->
    <main class="flex-1 flex flex-col relative min-w-0 h-full focus-gradient">
        <header class="h-16 border-b border-white/5 flex items-center justify-between px-6 shrink-0 bg-black/20 backdrop-blur-md">
            <div class="flex items-center gap-4 flex-1">
                <i class="fas fa-crosshairs text-indigo-400 text-xs"></i>
                <input id="task-input" type="text" placeholder="What are we doing right now?" class="bg-transparent border-none text-white font-semibold outline-none w-1/2 text-sm focus:ring-0 placeholder:text-white/10" onchange="updateActiveSession()">
                <div class="h-4 w-[1px] bg-white/10 hidden sm:block"></div>
                <input id="why-input" type="text" placeholder="The 'Why'..." class="bg-transparent border-none text-white/40 text-xs outline-none w-1/3 focus:ring-0 placeholder:text-white/5 hidden sm:block" onchange="updateActiveSession()">
            </div>

            <div class="flex items-center gap-4">
                <button onclick="triggerAuraIntel()" class="px-4 py-1.5 bg-indigo-600/10 border border-indigo-500/30 text-indigo-400 rounded-lg text-[10px] font-bold uppercase tracking-wider hover:bg-indigo-600/20 transition-all active:scale-95">
                    Aura Intel
                </button>
                <div class="px-3 py-1.5 bg-white/5 rounded-full border border-white/10 text-[10px] mono text-indigo-300">
                    <span id="timer">0M FLOW</span>
                </div>
            </div>
        </header>

        <section id="chat-container" class="flex-1 overflow-y-auto p-6 md:px-20 space-y-6 custom-scrollbar scroll-smooth">
            <div id="intel-display"></div>
            <div id="messages-anchor" class="space-y-6"></div>
        </section>

        <footer class="p-6 shrink-0">
            <div class="max-w-4xl mx-auto flex flex-col gap-3">
                <div class="flex items-center bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-1.5 shadow-2xl focus-within:border-indigo-500/40 transition-all group">
                    <input id="user-input" type="text" placeholder="Break the cycle of paralysis..." class="flex-1 bg-transparent text-white px-4 py-3 focus:outline-none placeholder:text-white/20 text-sm" onkeydown="if(event.key === 'Enter') handleMessage()">
                    <button id="send-btn" onclick="handleMessage()" class="p-3 bg-indigo-600 text-white rounded-xl hover:bg-indigo-500 transition-all active:scale-95 shadow-lg shadow-indigo-600/20">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
                <div id="retry-hint" class="hidden text-center message-fade-in">
                    <button onclick="handleMessage(true)" class="px-6 py-2.5 bg-indigo-600/10 border border-indigo-500/30 rounded-full text-[10px] text-indigo-400 hover:bg-indigo-600/20 transition-all mono uppercase tracking-[0.2em] font-bold shadow-lg shadow-indigo-500/5">
                        <i class="fas fa-satellite-dish mr-2 animate-pulse"></i> Re-Sync Signal
                    </button>
                </div>
            </div>
            <div class="mt-3 text-center">
                <p class="text-[9px] text-white/10 mono uppercase tracking-widest">Neural Encryption Active // Aura v2.5.0</p>
            </div>
        </footer>
    </main>

    <script>
        // Use a static identifier node to maintain the cyberpunk command aesthetic
        const nodeID = localStorage.getItem('aura_node_id') || 'NODE-' + Math.random().toString(36).substring(2, 8).toUpperCase();
        localStorage.setItem('aura_node_id', nodeID);
        document.getElementById('user-display').innerText = `${nodeID}`;

        let state = {
            sessions: [],
            activeId: null,
            isThinking: false,
            serverAwake: false,
            lastInput: "",
            retryPending: false
        };

        const thinkingPhrases = [
            "Syncing neural pathways",
            "Bypassing cognitive noise",
            "Calibrating micro-steps",
            "Mapping flow state",
            "Analyzing resistance"
        ];

        // --- Connection Monitoring (ADHD visual loops) ---
        async function startEnhancedMonitor() {
            const statusLabel = document.getElementById('server-status');
            const statusDot = document.getElementById('status-dot');
            const statusMsg = document.getElementById('status-msg');
            const retryHint = document.getElementById('retry-hint');
            
            let monitorInterval = 2500;

            const check = async () => {
                try {
                    const controller = new AbortController();
                    const id = setTimeout(() => controller.abort(), 4000);
                    const resp = await fetch('/api/sessions', { signal: controller.signal });
                    clearTimeout(id);

                    if (resp.ok) {
                        state.serverAwake = true;
                        statusLabel.innerText = "Neural Sync Active";
                        statusLabel.style.color = "#818cf8";
                        
                        statusDot.className = "w-2.5 h-2.5 rounded-full bg-indigo-400 pulse-indigo";
                        statusDot.style.boxShadow = "0 0 12px rgba(129, 140, 248, 0.8)";
                        
                        statusMsg.innerText = "Signal Strength: 100%";
                        statusMsg.style.opacity = "0.3";
                        
                        if(state.retryPending) retryHint.classList.remove('hidden');
                        monitorInterval = 30000; // Heartbeat when verified awake
                    } else {
                        throw new Error();
                    }
                } catch (e) {
                    state.serverAwake = false;
                    statusLabel.innerText = "Waking Aura";
                    statusLabel.style.color = "rgba(251, 191, 36, 0.7)";
                    
                    statusDot.className = "w-2.5 h-2.5 rounded-full pulse-amber";
                    statusDot.style.boxShadow = "none";
                    
                    statusMsg.innerText = "Bypassing Server Cold-Start...";
                    statusMsg.style.opacity = "0.8";
                    
                    monitorInterval = 3000; // Fast retry sequence during boot
                }
                setTimeout(check, monitorInterval);
            };
            check();
        }

        // --- Synchronize sessions from in-memory backend ---
        async function fetchSessions() {
            try {
                const response = await fetch('/api/sessions');
                if (!response.ok) throw new Error();
                
                state.sessions = await response.json();
                
                if (state.sessions.length > 0) {
                    if (!state.activeId) {
                        state.activeId = state.sessions[0].id;
                    }
                } else {
                    await createNewFlow();
                }
                
                renderAll();
                const loader = document.getElementById('loader');
                if (loader) { loader.style.opacity = '0'; setTimeout(() => loader.style.display = 'none', 500); }
            } catch (e) {
                console.error("Backend unreachable yet. Retrying...", e);
                setTimeout(fetchSessions, 2000);
            }
        }

        window.createNewFlow = async function() {
            try {
                const response = await fetch('/api/sessions', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                if (!response.ok) throw new Error();
                
                const newSession = await response.json();
                state.activeId = newSession.id;
                await fetchSessions();
            } catch (e) {
                console.error("Unable to create flow:", e);
            }
        }

        window.updateActiveSession = async function() {
            if (!state.activeId) return;
            const task = document.getElementById('task-input').value;
            const why = document.getElementById('why-input').value;

            try {
                await fetch(`/api/sessions/${state.activeId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ task, why })
                });
                
                // Keep UI updated immediately
                const session = state.sessions.find(s => s.id === state.activeId);
                if (session) {
                    session.task = task;
                    session.why = why;
                }
                renderAll();
            } catch (e) {
                console.error("Failed to save changes:", e);
            }
        }

        window.switchSession = function(id) {
            state.activeId = id;
            document.getElementById('intel-display').innerHTML = '';
            renderAll();
        }

        // --- Enhanced Chat Engine Logic (Direct API Sync) ---
        window.handleMessage = async function(isRetry = false) {
            const input = document.getElementById('user-input');
            const text = isRetry ? state.lastInput : input.value.trim();
            const active = state.sessions.find(s => s.id === state.activeId);
            const retryHint = document.getElementById('retry-hint');
            
            if (!text || state.isThinking || !active) return;

            state.lastInput = text;
            if (isRetry) {
                state.retryPending = false;
                retryHint.classList.add('hidden');
            }

            const currentMessages = active.messages || [];
            const localDisplayMessages = isRetry ? [...currentMessages] : [...currentMessages, { role: 'user', text }];
            
            if (!isRetry) input.value = '';
            state.isThinking = true;
            
            const randPhrase = thinkingPhrases[Math.floor(Math.random() * thinkingPhrases.length)];
            const thinkingMsg = state.serverAwake 
                ? `${randPhrase}...` 
                : "Engine Cold-Start: Re-routing neural connections (~50s)...";
            
            renderMessagesFor([...localDisplayMessages, { 
                role: 'bot', 
                text: `<span class="thinking-dots italic opacity-40 mono text-[11px]">${thinkingMsg}</span>` 
            }]);

            try {
                const response = await fetch(`/api/sessions/${state.activeId}/chat`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text })
                });

                if (!response.ok) throw new Error("Sync Outage");

                const data = await response.json();
                state.serverAwake = true;
                
                // Sync current state with updated session returned from express memory
                const idx = state.sessions.findIndex(s => s.id === state.activeId);
                if (idx !== -1) {
                    state.sessions[idx] = data.session;
                }
                
                renderAll();
                input.focus();

            } catch (e) {
                console.error("Aura Error:", e);
                state.serverAwake = false;
                state.retryPending = true;
                
                renderMessagesFor([...localDisplayMessages, { 
                    role: 'bot', 
                    text: "Signal lost. Aura is still booting or re-routing. **Wait for the status light in the sidebar to glow indigo, then try again.**" 
                }]);
            } finally {
                state.isThinking = false;
            }
        }

        window.triggerAuraIntel = function() {
            const active = state.sessions.find(s => s.id === state.activeId);
            if (!active?.task) return;
            const display = document.getElementById('intel-display');
            display.innerHTML = `<div class="p-4 bg-indigo-600/5 border border-indigo-500/20 rounded-xl mb-6 text-[10px] mono italic text-indigo-300 thinking-dots uppercase tracking-widest">Accessing Neural Database</div>`;
            setTimeout(() => {
                display.innerHTML = `
                    <div class="p-5 bg-indigo-600/10 border border-indigo-500/30 rounded-xl mb-6 message-fade-in shadow-xl shadow-indigo-600/5">
                        <div class="flex items-center justify-between mb-3">
                            <div class="text-[10px] font-bold text-indigo-400 uppercase tracking-[0.2em] mono">✨ Aura Intel // 01</div>
                            <button onclick="this.closest('.message-fade-in').remove()" class="text-white/20 hover:text-white"><i class="fas fa-times text-xs"></i></button>
                        </div>
                        <div class="text-sm text-indigo-100 leading-relaxed font-medium">
                            Status: **Executive Dysfunction Detected**. <br><br>Strategy: Treat ${active.task} as an experiment, not a chore. **Lower the stakes.** The first 2 minutes are the only thing that exists.
                        </div>
                    </div>`;
            }, 1200);
        }

        function renderAll() {
            const active = state.sessions.find(s => s.id === state.activeId);
            const list = document.getElementById('flow-list');
            if (list) {
                list.innerHTML = state.sessions.map(s => `
                    <div onclick="switchSession('${s.id}')" class="group flex items-center justify-between p-3 rounded-xl cursor-pointer transition-all border ${state.activeId === s.id ? 'bg-indigo-600/20 border-indigo-500/30 text-white shadow-lg shadow-indigo-500/5' : 'hover:bg-white/5 border-transparent text-slate-500'}">
                        <p class="truncate text-xs font-medium">${s.task || 'New Focus State'}</p>
                        <i class="fas fa-chevron-right text-[10px] opacity-0 group-hover:opacity-100 transition-opacity"></i>
                    </div>`).join('');
            }
            if (active) {
                document.getElementById('task-input').value = active.task || "";
                document.getElementById('why-input').value = active.why || "";
                document.getElementById('timer').innerText = `${active.minutes || 0}M FLOW`;
                renderMessagesFor(active.messages || []);
            }
        }

        function renderMessagesFor(messages) {
            const container = document.getElementById('messages-anchor');
            if (!container) return;
            container.innerHTML = messages.map(m => `
                <div class="flex ${m.role === 'user' ? 'justify-end' : 'justify-start'} message-fade-in">
                    <div class="max-w-[85%] p-4 rounded-2xl text-sm leading-relaxed ${m.role === 'user' ? 'bg-white text-black font-semibold shadow-xl shadow-white/5' : 'bg-white/5 border border-white/10 text-slate-200 shadow-sm'}">
                        ${m.text.replace(/\n/g, '<br>').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}
                    </div>
                </div>`).join('');
            
            const chat = document.getElementById('chat-container');
            if (chat) {
                const lastMsg = container.lastElementChild;
                if(lastMsg) lastMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        }

        // Background Flow Clock
        setInterval(async () => {
            if (state.activeId) {
                const active = state.sessions.find(s => s.id === state.activeId);
                if (active && active.task) {
                    const newMinutes = (active.minutes || 0) + 1;
                    try {
                        await fetch(`/api/sessions/${state.activeId}`, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ minutes: newMinutes })
                        });
                        active.minutes = newMinutes;
                        renderAll();
                    } catch (e) {
                        console.error("Timer failed to sync:", e);
                    }
                }
            }
        }, 60000);

        // App Start Check
        startEnhancedMonitor();
        fetchSessions();
    </script>
</body>
</html>
